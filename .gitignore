data/runs/*
!data/runs/.gitkeep
data/exports/*
!data/exports/.gitkeep
data/backups/*
!data/backups/.gitkeep

# ─── Database ─────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ─── Logs ─────────────────────────────────────────────
*.log
logs/

